# === Server ===
PORT=8000
NODE_ENV=development

# === MongoDB ===
MONGODB_URI=mongodb://localhost:27017/queuestorm
MONGODB_DB_NAME=queuestorm

# === AI Providers ===
# Primary: Google Gemini 2.5 Flash (free tier)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Fallback: Groq (free tier — Llama 3.3 70B)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# AI provider selection (primary | groq | rule_only)
AI_PROVIDER=primary

# === Security ===
# Internal API key — judges send this via X-Api-Key header. If unset, /health
# remains public but /analyze-ticket and friends are open (dev mode only).
INTERNAL_API_KEY=
JWT_SECRET=replace_with_a_min_32_char_secret_value_xyz
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=replace_with_a_min_32_char_secret_value_abc
REFRESH_TOKEN_EXPIRES_IN=7d

# === Rate Limiting ===
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# === Logging ===
LOG_LEVEL=info

# === CORS ===
CORS_ORIGIN=*

# === Timeouts ===
LLM_TIMEOUT_MS=25000